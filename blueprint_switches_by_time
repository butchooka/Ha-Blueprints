blueprint:
  name: Zeitgesteuerte Steckdosen (Wochentag / Wochenende)
  description: >
    Schaltet definierte Geräte abhängig von Uhrzeiten ein und aus.
    Unterscheidet zwischen Wochentagen und Wochenende anhand
    des Workday-Sensors.
  domain: automation

  input:
    workday_sensor:
      name: Workday Sensor
      description: Sensor zur Erkennung von Wochentagen
      default: binary_sensor.workday_sensor
      selector:
        entity:
          domain: binary_sensor

    targets:
      name: Zu schaltende Geräte
      description: Steckdosen oder Schalter
      selector:
        target:
          entity:
            domain: switch

    weekday_on_time:
      name: Einschaltzeit Wochentags
      selector:
        time:

    weekday_off_time:
      name: Ausschaltzeit Wochentags
      selector:
        time:

    weekend_on_time:
      name: Einschaltzeit Wochenende
      selector:
        time:

    weekend_off_time:
      name: Ausschaltzeit Wochenende
      selector:
        time:

mode: single

trigger:
  - platform: time
    at: !input weekday_on_time
    id: weekday_on

  - platform: time
    at: !input weekday_off_time
    id: weekday_off

  - platform: time
    at: !input weekend_on_time
    id: weekend_on

  - platform: time
    at: !input weekend_off_time
    id: weekend_off

condition: []

action:
  - choose:
      # Wochentag - EIN
      - conditions:
          - condition: trigger
            id: weekday_on
          - condition: state
            entity_id: !input workday_sensor
            state: "on"
        sequence:
          - service: homeassistant.turn_on
            target: !input targets

      # Wochentag - AUS
      - conditions:
          - condition: trigger
            id: weekday_off
          - condition: state
            entity_id: !input workday_sensor
            state: "on"
        sequence:
          - service: homeassistant.turn_off
            target: !input targets

      # Wochenende - EIN
      - conditions:
          - condition: trigger
            id: weekend_on
          - condition: state
            entity_id: !input workday_sensor
            state: "off"
        sequence:
          - service: homeassistant.turn_on
            target: !input targets

      # Wochenende - AUS
      - conditions:
          - condition: trigger
            id: weekend_off
          - condition: state
            entity_id: !input workday_sensor
            state: "off"
        sequence:
          - service: homeassistant.turn_off
            target: !input targets
