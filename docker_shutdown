blueprint:
  name: Schalter per Label morgens ein / abends aus (mit Workday, Delay-Loop & Zusatzlabels)
  description: >
    Aktiviert morgens Geräte basierend auf Labels und schaltet sie abends aus.
    Unterschiedliche Zeiten für Wochentage und Wochenende.
    Abendliches Ausschalten wird verzögert, wenn Verbrauch hoch ist oder Lampen an sind.
    Verzögerung wird wiederholt geprüft. Zusätzlich: Geräte, die nur ein- oder nur ausgeschaltet werden.
  domain: automation

  input:
    label_entities:
      name: Hauptgeräte (ein & aus)
      selector:
        entity:
          multiple: true
          domain: switch

    label_entities_only_on:
      name: Geräte nur einschalten
      default: []
      selector:
        entity:
          multiple: true
          domain: switch

    label_entities_only_off:
      name: Geräte nur ausschalten
      default: []
      selector:
        entity:
          multiple: true
          domain: switch

    morning_time_weekday:
      name: Einschaltzeit Wochentage
      selector:
        time:

    morning_time_weekend:
      name: Einschaltzeit Wochenende
      selector:
        time:

    evening_time_weekday:
      name: Ausschaltzeit Wochentage
      selector:
        time:

    evening_time_weekend:
      name: Ausschaltzeit Wochenende
      selector:
        time:

    workday_sensor:
      name: Workday Sensor
      selector:
        entity:
          domain: binary_sensor

    power_sensor:
      name: Verbrauchssensor (optional)
      default: ""
      selector:
        entity:
          domain: sensor

    power_threshold:
      name: Verbrauchsschwelle
      default: 0
      selector:
        number:
          min: 0
          max: 5000
          unit_of_measurement: W

    lamps_to_check:
      name: Lampen, die noch an sein könnten
      selector:
        entity:
          multiple: true
          domain: light

    delay_minutes:
      name: Verzögerungsdauer (Minuten)
      default: 30
      selector:
        number:
          min: 1
          max: 120
          unit_of_measurement: min

mode: restart

trigger:
  - platform: time
