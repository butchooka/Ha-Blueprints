blueprint:
  name: Geräte morgens ein / abends aus (robust)
  domain: automation

  input:
    target_main:
      name: Haupt-Ziel (ein & aus)
      selector:
        target: {}

    target_only_on:
      name: Nur Einschalten
      default: {}
      selector:
        target: {}

    target_only_off:
      name: Nur Ausschalten
      default: {}
      selector:
        target: {}

    morning_time_weekday:
      selector:
        time:

    morning_time_weekend:
      selector:
        time:

    evening_time_weekday:
      selector:
        time:

    evening_time_weekend:
      selector:
        time:

    workday_sensor:
      selector:
        entity:
          domain: binary_sensor

    power_sensor:
      default: ""
      selector:
        entity:
          domain: sensor

    power_threshold:
      default: 0
      selector:
        number:
          min: 0
          max: 5000

    lamps_to_check:
      selector:
        entity:
          domain: light
          multiple: true

    delay_minutes:
      default: 30
      selector:
        number:
          min: 1
          max: 120

mode: restart

trigger:
  - platform: time
    at: !input morning_time_weekday
    id: morning_weekday

  - platform: time
    at: !input morning_time_weekend
    id: morning_weekend

  - platform: time
    at: !input evening_time_weekday
    id: evening_weekday

  - platform: time
    at: !input evening_time_weekend
    id: evening_weekend

action:
  - choose:

      # MORGEN WERKTAG
      - conditions:
          - condition: trigger
            id: morning_weekday
          - condition: state
            entity_id: !input workday_sensor
            state: "on"
        sequence:
          - service: homeassistant.turn_on
            target: !input target_main

          - service: homeassistant.turn_on
            target: !input target_only_on

      # MORGEN WOCHENENDE
      - conditions:
          - condition: trigger
            id: morning_weekend
          - condition: state
            entity_id: !input workday_sensor
            state: "off"
        sequence:
          - service: homeassistant.turn_on
            target: !input target_main

          - service: homeassistant.turn_on
            target: !input target_only_on

      # ABEND WERKTAG
      - conditions:
          - condition: trigger
            id: evening_weekday
          - condition: state
            entity_id: !input workday_sensor
            state: "on"
        sequence:
          - repeat:
              while:
                - condition: or
                  conditions:
                    - condition: template
                      value_template: >
                        {% set sensor = !input power_sensor %}
                        {% if sensor != "" %}
                          {{ states(sensor) | float(0) > (!input power_threshold) }}
                        {% else %}
                          false
                        {% endif %}
                    - condition: state
                      entity_id: !input lamps_to_check
                      state: "on"
              sequence:
                - delay:
                    minutes: !input delay_minutes

          - service: homeassistant.turn_off
            target: !input target_main

          - service: homeassistant.turn_off
            target: !input target_only_off

      # ABEND WOCHENENDE
      - conditions:
          - condition: trigger
            id: evening_weekend
          - condition: state
            entity_id: !input workday_sensor
            state: "off"
        sequence:
          - repeat:
              while:
                - condition: or
                  conditions:
                    - condition: template
                      value_template: >
                        {% set sensor = !input power_sensor %}
                        {% if sensor != "" %}
                          {{ states(sensor) | float(0) > (!input power_threshold) }}
                        {% else %}
                          false
                        {% endif %}
                    - condition: state
                      entity_id: !input lamps_to_check
                      state: "on"
              sequence:
                - delay:
                    minutes: !input delay_minutes

          - service: homeassistant.turn_off
            target: !input target_main

          - service: homeassistant.turn_off
            target: !input target_only_off
