blueprint:
  name: Geräte per Target morgens ein / abends aus (stabil, Workday, Delay-Loop)
  description: >
    Steuerung von Geräten anhand eines Target-Selectors (Entity, Device, Area, Label).
    Unterstützt:
    - Hauptgruppe (ein & aus)
    - Nur-Einschalten-Gruppe
    - Nur-Ausschalten-Gruppe
    - Workday-Zeiten
    - Wiederholte Verzögerung bei Verbrauch/Licht
  domain: automation

  input:
    target_main:
      name: Haupt-Ziel (ein & aus)
      selector:
        target: {}

    target_only_on:
      name: Ziel nur für Einschalten
      default: {}
      selector:
        target: {}

    target_only_off:
      name: Ziel nur für Ausschalten
      default: {}
      selector:
        target: {}

    morning_time_weekday:
      name: Einschaltzeit Wochentage
      selector:
        time:

    morning_time_weekend:
      name: Einschaltzeit Wochenende
      selector:
        time:

    evening_time_weekday:
      name: Ausschaltzeit Wochentage
      selector:
        time:

    evening_time_weekend:
      name: Ausschaltzeit Wochenende
      selector:
        time:

    workday_sensor:
      name: Workday Sensor
      selector:
        entity:
          domain: binary_sensor

    power_sensor:
      name: Verbrauchssensor (optional)
      default: ""
      selector:
        entity:
          domain: sensor

    power_threshold:
      name: Verbrauchsschwelle
      default: 0
      selector:
        number:
          min: 0
          max: 5000
          unit_of_measurement: W

    lamps_to_check:
      name: Lampen, die noch an sein könnten
      selector:
        entity:
          multiple: true
          domain: light

    delay_minutes:
      name: Verzögerungsdauer (Minuten)
      default: 30
      selector:
        number:
          min: 1
          max: 120
          unit_of_measurement: min

mode: restart

variables:
  main_entities: >
    {{ i.target_main.entity_id | default([], true) }}

  only_on_entities: >
    {{ i.target_only_on.entity_id | default([], true) }}

  only_off_entities: >
    {{ i.target_only_off.entity_id | default([], true) }}

trigger:
  - platform: time
    at: !input morning_time_weekday
    id: morning_weekday
  - platform: time
    at: !input morning_time_weekend
    id: morning_weekend
  - platform: time
    at: !input evening_time_weekday
    id: evening_weekday
  - platform: time
    at: !input evening_time_weekend
    id: evening_weekend

action:
  - choose:

      # --- MORGENS ---
      - conditions:
          - condition: trigger
            id: morning_weekday
          - condition: state
            entity_id: !input workday_sensor
            state: "on"
        sequence:
          - service: homeassistant.turn_on
            target:
              entity_id: "{{ main_entities + only_on_entities }}"

      - conditions:
          - condition: trigger
            id: morning_weekend
          - condition: state
            entity_id: !input workday_sensor
            state: "off"
        sequence:
          - service: homeassistant.turn_on
            target:
              entity_id: "{{ main_entities + only_on_entities }}"

      # --- ABENDS ---
      - conditions:
          - condition: trigger
            id: evening_weekday
          - condition: state
            entity_id: !input workday_sensor
            state: "on"
        sequence:
          - repeat:
              while:
                - condition: or
                  conditions:
                    - condition: template
                      value_template: >
                        {% if i.power_sensor != "" %}
                        {{ states(i.power_sensor) | float(0) > i.power_threshold }}
                        {% else %}
                        false
                        {% endif %}
                    - condition: state
                      entity_id: !input lamps_to_check
                      state: "on"
              sequence:
                - delay:
                    minutes: !input delay_minutes

          - service: homeassistant.turn_off
            target:
              entity_id: "{{ main_entities + only_off_entities }}"

      - conditions:
          - condition: trigger
            id: evening_weekend
          - condition: state
            entity_id: !input workday_sensor
            state: "off"
        sequence:
          - repeat:
              while:
                - condition: or
                  conditions:
                    - condition: template
                      value_template: >
                        {% if i.power_sensor != "" %}
                        {{ states(i.power_sensor) | float(0) > i.power_threshold }}
                        {% else %}
                        false
                        {% endif %}
                    - condition: state
                      entity_id: !input lamps_to_check
                      state: "on"
              sequence:
                - delay:
                    minutes: !input delay_minutes

          - service: homeassistant.turn_off
            target:
              entity_id: "{{ main_entities + only_off_entities }}"
