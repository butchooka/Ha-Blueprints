blueprint:
  name: TV Master / Slave Switches
  description: >
    Schaltet Geräte ein, wenn der Stromverbrauch eines Sensors
    über einen Schwellwert steigt und schaltet sie nach einer
    Verzögerung wieder aus, wenn der Verbrauch stabil sinkt.
  domain: automation

  input:
    power_sensor:
      name: Leistungssensor
      selector:
        entity:
          domain: sensor

    power_threshold:
      name: Leistungsschwellwert (Watt)
      default: 20
      selector:
        number:
          min: 5
          max: 100
          unit_of_measurement: W

    targets_on:
      name: Geräte einschalten
      selector:
        target:
          entity:
            domain: switch

    off_delay:
      name: Ausschaltverzögerung (Minuten)
      default: 10
      selector:
        number:
          min: 1
          max: 60
          unit_of_measurement: Min

mode: single

trigger:
  - platform: numeric_state
    entity_id: !input power_sensor
    above: !input power_threshold
    id: power_high

  - platform: numeric_state
    entity_id: !input power_sensor
    below: !input power_threshold
    for:
      minutes: 2
    id: power_low

action:
  - choose:
      - conditions:
          - condition: trigger
            id: power_high
        sequence:
          - service: homeassistant.turn_on
            target: !input targets_on

      - conditions:
          - condition: trigger
            id: power_low
        sequence:
          - delay:
              minutes: !input off_delay
          - condition: numeric_state
            entity_id: !input power_sensor
            below: !input power_threshold
          - service: homeassistant.turn_off
            target: !input targets_on
